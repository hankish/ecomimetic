{% set navPages = collections.all | eleventyNavigation("manual") %}


<nav class="manual-toc">
  <ul class="toc-list">
    {% for entry in navPages %}
      <li class="toc-section">
        <span class="toc-section-label">{{ entry.title }}</span>
        {% if entry.children.length %}
          <ul class="toc-sublist">
            {% for child in entry.children %}
              <li class="toc-item{% if child.children.length %} toc-item--has-children{% endif %}">
                {% if child.children.length %}
                  <div class="toc-row">
                    <button class="toc-toggle" aria-expanded="true" aria-label="Toggle {{ child.title }}">›</button>
                    <a href="{{ child.url }}" class="toc-link{% if child.url == page.url %} toc-link--active{% endif %}">{{ child.title }}</a>
                  </div>
                  <ul class="toc-sublist toc-sublist--deep">
                    {% for grandchild in child.children %}
                      <li class="toc-item{% if grandchild.children.length %} toc-item--has-children toc-item--collapsed{% endif %}">
                        {% if grandchild.children.length %}
                          <div class="toc-row">
                            <button class="toc-toggle" aria-expanded="false" aria-label="Toggle {{ grandchild.title }}">›</button>
                            <a href="{{ grandchild.url }}" class="toc-link{% if grandchild.url == page.url %} toc-link--active{% endif %}">{{ grandchild.title }}</a>
                          </div>
                          <ul class="toc-sublist toc-sublist--deepest">
                            {% for leaf in grandchild.children %}
                              <li class="toc-item">
                                <div class="toc-row">
                                  <span class="toc-spacer"></span>
                                  <a href="{{ leaf.url }}" class="toc-link{% if leaf.url == page.url %} toc-link--active{% endif %}">{{ leaf.title }}</a>
                                </div>
                              </li>
                            {% endfor %}
                          </ul>
                        {% else %}
                          <div class="toc-row">
                            <span class="toc-spacer"></span>
                            <a href="{{ grandchild.url }}" class="toc-link{% if grandchild.url == page.url %} toc-link--active{% endif %}">{{ grandchild.title }}</a>
                          </div>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% else %}
                  <div class="toc-row">
                    <span class="toc-spacer"></span>
                    <a href="{{ child.url }}" class="toc-link{% if child.url == page.url %} toc-link--active{% endif %}">{{ child.title }}</a>
                  </div>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>
