<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">

      <a href="/" class="site-name">Ecomimetic Design</a>

      <a href="/" class="site-logo-link" aria-label="Home">
        <img src="/assets/images/logo.svg" alt="" class="site-logo" width="40" height="40">
      </a>

      <nav class="site-nav" id="site-nav" aria-label="Main navigation">
        <a href="/participate/" class="nav-link">Participate</a>
        <a href="/about/" class="nav-link">About</a>
        <a href="/media/" class="nav-link">Media</a>
        <a href="/manual/" class="nav-link nav-btn">Manual</a>
      </nav>

      <button class="hamburger" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>

    </div>
  </header>

  <main class="content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>&copy; {{ site.title }}</p>
  </footer>

  <script type="module" src="/assets/js/main.js"></script>
</body>
</html>
