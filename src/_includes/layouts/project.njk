<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  {% include "partials/site-header.njk" %}

  <main class="content">
    <h1>{{ title }}</h1>

    {% if description %}
      <p class="lead">{{ description }}</p>
    {% endif %}

    {% if url %}
      <p>
        <wa-button href="{{ url }}" target="_blank" rel="noopener noreferrer">
          <wa-icon name="arrow-up-right-from-square" slot="prefix"></wa-icon>
          View Project
        </wa-button>
      </p>
    {% endif %}

    {{ content | safe }}

    {% if pages and pages.length %}
      <section class="related-list">
        <h2>Related Pages</h2>
        <ul>
          {% for pageId in pages %}
            {% for refPage in collections.referencePages %}
              {% if refPage.data.id == pageId %}
                <li>
                  <a href="{{ refPage.url }}">{{ refPage.data.id }}: {{ refPage.data.title }}</a>
                  {% if refPage.data.description %} — {{ refPage.data.description }}{% endif %}
                </li>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </ul>
      </section>
    {% endif %}
  </main>

  {% include "partials/site-footer.njk" %}

  <script type="module" src="/assets/js/main.js"></script>
</body>
</html>
