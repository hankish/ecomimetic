{% extends "layouts/_shell.njk" %}

{% block head %}
  <title>{{ title }} — {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
{% endblock %}

{% block body %}
  <main class="content">
    <h1>{{ title }}</h1>

    {% if description %}
      <p class="lead">{{ description }}</p>
    {% endif %}

    {% if url %}
      <p>
        <wa-button href="{{ url }}" target="_blank" rel="noopener noreferrer">
          <wa-icon name="arrow-up-right-from-square" slot="prefix"></wa-icon>
          View Project
        </wa-button>
      </p>
    {% endif %}

    {{ content | safe }}

    {% if pages and pages.length %}
      <section class="related-list">
        <h2>Related Pages</h2>
        <ul>
          {% for pageId in pages %}
            {% for refPage in collections.referencePages %}
              {% if refPage.data.id == pageId %}
                <li>
                  <a href="{{ refPage.url }}">{{ refPage.data.id }}: {{ refPage.data.title }}</a>
                  {% if refPage.data.description %} — {{ refPage.data.description }}{% endif %}
                </li>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </ul>
      </section>
    {% endif %}
  </main>
{% endblock %}
